server:
  port: 8899
  threads: 2

mqtt:
  broker: "192.168.2.15"
  port: 1883
  username: "aamat"
  password: "exploracion"
  client_id: "hms_tuya"
  topic_prefix: "hms-tuya"

devices_file: "devices.json"

tuya:
  mode: "persistent"       # "persistent" (keep TCP alive) or "burst" (fresh connection per poll)
  poll_interval: 10        # seconds between status polls
  heartbeat_interval: 10   # seconds between heartbeats (persistent mode only)
  socket_timeout: 5        # TCP timeout per device
  min_backoff: 10          # initial backoff on failure (seconds)
  max_backoff: 300         # maximum backoff (seconds)
  cmd_max_retries: 5
  cmd_retry_delay: 3
  cmd_timeout: 60
